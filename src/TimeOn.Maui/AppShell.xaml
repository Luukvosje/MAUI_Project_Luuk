<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TimeOn.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="TimeOn"
    FlyoutBehavior="Disabled">

    <ShellContent
        x:Name="LoginShell"
        Route="LoginPage"
        Title="Inloggen" />

    <TabBar x:Name="MainTabBar" Route="main">
        <ShellContent x:Name="DashboardShell" Route="DashboardPage" Title="Overzicht" />
        <ShellContent x:Name="TripsShell" Route="TripsPage" Title="Ritten" />
        <ShellContent x:Name="CustomersShell" Route="CustomersPage" Title="Klanten" />
        <ShellContent x:Name="TrackingShell" Route="TrackingPage" Title="Registratie" />
        <ShellContent x:Name="SettingsShell" Route="SettingsPage" Title="Instellingen" />
    </TabBar>

</Shell>
