<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Brand -->
    <Color x:Key="Primary">#d40f7d</Color>
    <Color x:Key="PrimaryDark">#a80c63</Color>
    <Color x:Key="PrimaryLight">#fce8f3</Color>
    <Color x:Key="Secondary">#F9EE4C</Color>
    <Color x:Key="SecondaryDark">#c4b83a</Color>
    <Color x:Key="Tertiary">#2d1035</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#212529</Color>
    <Color x:Key="TextSecondary">#6c757d</Color>
    <Color x:Key="TextDisabled">#adb5bd</Color>

    <!-- Surfaces -->
    <Color x:Key="White">#ffffff</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Surface">#ffffff</Color>
    <Color x:Key="SurfaceAlt">#f8f9fa</Color>
    <Color x:Key="Background">#f8f9fa</Color>
    <Color x:Key="Border">#dee2e6</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#198754</Color>
    <Color x:Key="Warning">#fd7e14</Color>
    <Color x:Key="Error">#dc3545</Color>
    <Color x:Key="Info">#0dcaf0</Color>

    <!-- Grays -->
    <Color x:Key="Gray100">#f8f9fa</Color>
    <Color x:Key="Gray200">#e9ecef</Color>
    <Color x:Key="Gray300">#dee2e6</Color>
    <Color x:Key="Gray400">#ced4da</Color>
    <Color x:Key="Gray500">#adb5bd</Color>
    <Color x:Key="Gray600">#6c757d</Color>
    <Color x:Key="Gray900">#212529</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
</ResourceDictionary>
