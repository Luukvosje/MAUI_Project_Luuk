<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Maui.Features.Customers.ViewModels"
             xmlns:views="clr-namespace:TimeOn.Maui.Features.Customers.Views"
             x:Class="TimeOn.Maui.Features.Customers.Views.CustomerFormPage"
             x:DataType="vm:CustomerFormViewModel"
             Title="{Binding Title}"
             SafeAreaEdges="All">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PageContentPadding}"
                             Spacing="{StaticResource SpacingMedium}">
            <Border Style="{StaticResource AppCard}">
                <views:CustomerFormView />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
