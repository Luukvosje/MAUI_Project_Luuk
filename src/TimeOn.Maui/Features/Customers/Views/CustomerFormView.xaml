<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Maui.Features.Customers.ViewModels"
             x:Class="TimeOn.Maui.Features.Customers.Views.CustomerFormView"
             x:Name="FormView"
             x:DataType="vm:CustomerFormViewModel">

    <VerticalStackLayout Spacing="{StaticResource SpacingSmall}">
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center" />
        <Label Text="{Binding ErrorMessage}"
               Style="{StaticResource ErrorLabel}" />

        <Label Text="Naam"
               Style="{StaticResource SectionTitle}" />
        <Border Style="{StaticResource FormEntryBorder}">
            <Entry Text="{Binding Name}"
                   Placeholder="Klantnaam" />
        </Border>

        <Label Text="Contact e-mail"
               Style="{StaticResource SectionTitle}"
               Margin="0,8,0,0" />
        <Border Style="{StaticResource FormEntryBorder}">
            <Entry Text="{Binding ContactEmail}"
                   Placeholder="naam@bedrijf.nl"
                   Keyboard="Email" />
        </Border>

        <Label Text="Adres"
               Style="{StaticResource SectionTitle}"
               Margin="0,8,0,0" />
        <Border Style="{StaticResource FormEntryBorder}">
            <Entry Text="{Binding Address}"
                   Placeholder="Straat, plaats" />
        </Border>

        <Grid ColumnDefinitions="*,Auto"
              Margin="0,8,0,0">
            <Label Text="Actief"
                   Style="{StaticResource SectionTitle}"
                   VerticalOptions="Center" />
            <Switch Grid.Column="1"
                    IsToggled="{Binding IsActive}" />
        </Grid>

        <Button Text="Opslaan"
                Style="{StaticResource PrimaryButton}"
                Margin="0,16,0,0"
                Command="{Binding SaveCommand, Source={x:Reference FormView}}" />
        <Button Text="Annuleren"
                Style="{StaticResource SecondaryButton}"
                Command="{Binding CancelCommand, Source={x:Reference FormView}}" />
    </VerticalStackLayout>
</ContentView>
