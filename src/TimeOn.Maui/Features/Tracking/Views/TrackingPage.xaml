<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Maui.Features.Tracking.ViewModels"
             x:Class="TimeOn.Maui.Features.Tracking.Views.TrackingPage"
             x:DataType="vm:TrackingViewModel"
             Title="Tracking"
             SafeAreaEdges="All">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PageContentPadding}"
                             Spacing="{StaticResource SpacingMedium}">
            <Border Style="{StaticResource AppCard}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsTracking}"
                                 Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" />
                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Border.Triggers>
                <VerticalStackLayout Spacing="{StaticResource SpacingSmall}">
                    <HorizontalStackLayout Spacing="10">
                        <BoxView Style="{StaticResource StatusIndicator}">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView"
                                             Binding="{Binding IsTracking}"
                                             Value="True">
                                    <Setter Property="Color" Value="{StaticResource Primary}" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                        <Label Text="Status"
                               Style="{StaticResource SectionTitle}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding StatusText}"
                           FontFamily="OpenSansSemibold"
                           FontSize="16"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                    <Label Text="GPS points are recorded while tracking is active."
                           Style="{StaticResource BodySecondary}"
                           IsVisible="{Binding IsTracking}" />
                    <Label Text="Press Start to begin a new work session."
                           Style="{StaticResource BodySecondary}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding IsTracking}"
                                         Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorLabel}"
                   IsVisible="{Binding HasError}" />

            <Border Style="{StaticResource AppCard}">
                <VerticalStackLayout Spacing="{StaticResource SpacingSmall}">
                    <Label Text="Controls"
                           Style="{StaticResource SectionTitle}" />
                    <Button Text="Start tracking"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}" />
                    <Button Text="Stop tracking"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding StopCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource AppCard}"
                    IsVisible="{Binding ShowDevelopmentTools}">
                <VerticalStackLayout Spacing="{StaticResource SpacingSmall}">
                    <Label Text="Development"
                           Style="{StaticResource SectionTitle}" />
                    <Label Text="Paste the full contents of points.json (JSON array)."
                           Style="{StaticResource BodySecondary}" />
                    <Border Style="{StaticResource FormEntryBorder}"
                            Padding="12">
                        <Editor Text="{Binding GpsPointsJson}"
                                Placeholder="Paste the JSON array from points.json here"
                                HeightRequest="280"
                                IsSpellCheckEnabled="False"
                                IsTextPredictionEnabled="False" />
                    </Border>
                    <Button Text="Save work session"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SaveImportedWorkSessionCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
