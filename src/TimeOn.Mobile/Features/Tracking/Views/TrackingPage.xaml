<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Mobile.Features.Tracking.ViewModels"
             x:Class="TimeOn.Mobile.Features.Tracking.Views.TrackingPage"
             x:DataType="vm:TrackingViewModel"
             Title="Tracking">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Tracker Modus" FontSize="24" FontAttributes="Bold" />
            <Label Text="{Binding StatusText}" FontSize="16" />
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Button Text="Start" Command="{Binding StartCommand}" />
            <Button Text="Stop" Command="{Binding StopCommand}" />

            <BoxView HeightRequest="1"
                     Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                     IsVisible="{Binding ShowDevelopmentTools}" />

            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding ShowDevelopmentTools}">
                <Label Text="Development"
                       FontSize="18"
                       FontAttributes="Bold" />
                <Label Text="Plak de volledige inhoud van points.json (JSON-array)."
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                <Editor Text="{Binding GpsPointsJson}"
                        Placeholder="Plak hier de JSON-array uit points.json"
                        HeightRequest="320"
                        IsSpellCheckEnabled="False"
                        IsTextPredictionEnabled="False" />
                <Button Text="Worksession opslaan"
                        Command="{Binding SaveImportedWorkSessionCommand}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
