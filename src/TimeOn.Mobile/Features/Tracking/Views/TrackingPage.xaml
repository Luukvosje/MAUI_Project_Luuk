<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Mobile.Features.Tracking.ViewModels"
             x:Class="TimeOn.Mobile.Features.Tracking.Views.TrackingPage"
             x:DataType="vm:TrackingViewModel"
             Title="Tracking">

    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="GPS Tracking" FontSize="24" />
        <Button Text="Toggle tracking" Command="{Binding ToggleTrackingCommand}" />
    </VerticalStackLayout>
</ContentPage>
