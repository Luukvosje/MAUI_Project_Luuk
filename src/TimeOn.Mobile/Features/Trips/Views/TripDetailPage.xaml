<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Mobile.Features.Trips.ViewModels"
             xmlns:views="clr-namespace:TimeOn.Mobile.Features.Trips.Views"
             x:Class="TimeOn.Mobile.Features.Trips.Views.TripDetailPage"
             x:Name="TripDetailPageRoot"
             x:DataType="vm:TripDetailViewModel"
             Title="{Binding Title}">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
            <Button Text="Back"
                    Command="{Binding GoBackCommand}" />
            <Label Grid.Column="1"
                   Text="Trip details"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Button Grid.Column="2"
                    Text="Delete"
                    TextColor="{StaticResource Error}"
                    BackgroundColor="Transparent"
                    Command="{Binding DeleteCommand}" />
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="6">
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}" />
            <Label Text="{Binding StartLabel, StringFormat='Started: {0}'}" />
            <Label Text="{Binding EndLabel, StringFormat='Ended: {0}'}" />
            <Label Text="{Binding Status, StringFormat='Status: {0}'}" />
            <Label Text="{Binding TotalDistanceKm, StringFormat='Total: {0:F2} km'}" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="12">
                <Label Text="Segments" FontSize="18" FontAttributes="Bold" />

                <CollectionView ItemsSource="{Binding Segments}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="No segments recorded for this trip." />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SegmentListItem">
                            <Border StrokeThickness="1"
                                    Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Title}"
                                           FontAttributes="Bold" />

                                    <Label Text="Start"
                                           FontAttributes="Bold" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <DatePicker Date="{Binding StartDate}" />
                                        <TimePicker Grid.Column="1"
                                                    Time="{Binding StartTime}" />
                                    </Grid>

                                    <Label Text="End"
                                           FontAttributes="Bold" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <DatePicker Date="{Binding EndDate}" />
                                        <TimePicker Grid.Column="1"
                                                    Time="{Binding EndTime}" />
                                    </Grid>

                                    <VerticalStackLayout IsVisible="{Binding IsDriving}" Spacing="4">
                                        <Label Text="Distance (km)"
                                               FontAttributes="Bold" />
                                        <Entry Text="{Binding DistanceKmText}"
                                               Keyboard="Numeric"
                                               Placeholder="0.00" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout IsVisible="{Binding IsStationary}" Spacing="4">
                                        <Label Text="Customer"
                                               FontAttributes="Bold" />
                                        <Picker ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type views:TripDetailPage}}, Path=BindingContext.CustomerOptions}"
                                                ItemDisplayBinding="{Binding Name}"
                                                SelectedItem="{Binding SelectedCustomer}" />
                                    </VerticalStackLayout>

                                    <Button Text="Save segment"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type views:TripDetailPage}}, Path=BindingContext.SaveSegmentCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
