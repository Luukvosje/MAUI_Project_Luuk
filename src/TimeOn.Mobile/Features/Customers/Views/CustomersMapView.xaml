<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimeOn.Mobile.Features.Customers.Views.CustomersMapView"
             x:Name="MapView">

    <Grid>
        <Grid x:Name="NativeMapHost"
              IsVisible="{Binding IsNativeMapVisible, Source={x:Reference MapView}}" />

        <WebView x:Name="CustomersWebMap"
                 IsVisible="{Binding IsWebMapVisible, Source={x:Reference MapView}}" />
    </Grid>
</ContentView>
