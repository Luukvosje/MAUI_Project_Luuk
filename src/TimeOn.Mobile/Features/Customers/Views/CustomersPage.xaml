<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Mobile.Features.Customers.ViewModels"
             xmlns:views="clr-namespace:TimeOn.Mobile.Features.Customers.Views"
             xmlns:dto="clr-namespace:TimeOn.Application.Features.Customers.DTOs;assembly=TimeOn.Application"
             x:Class="TimeOn.Mobile.Features.Customers.Views.CustomersPage"
             x:DataType="vm:CustomersViewModel"
             Title="Customers">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
        <Label Grid.Row="0" Text="Customers" FontSize="24" />

        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Button Text="List" Command="{Binding ShowListCommand}" />
            <Button Text="Map" Command="{Binding ShowMapCommand}" />
            <Button Text="Create" Command="{Binding CreateCustomerCommand}" />
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}" />
        </VerticalStackLayout>

        <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="8">
            <HorizontalStackLayout Grid.Row="0"
                                   Spacing="8"
                                   IsVisible="{Binding HasSelectedCustomer}">
                <Label Text="{Binding SelectedCustomerName, StringFormat='Selected: {0}'}"
                       VerticalOptions="Center" />
                <Button Text="Edit" Command="{Binding EditSelectedCustomerCommand}" />
                <Button Text="Delete" Command="{Binding DeleteSelectedCustomerCommand}" />
            </HorizontalStackLayout>

            <Grid Grid.Row="1">
                <CollectionView IsVisible="{Binding IsListView}"
                                ItemsSource="{Binding Customers}"
                                SelectedItem="{Binding SelectedCustomer}"
                                SelectionMode="Single">  
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:CustomerDto">
                            <Border Padding="12" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" />
                                    <Label Text="{Binding ContactEmail}" />
                                    <Label Text="{Binding Address}" />
                                    <Label Text="{Binding IsActive, StringFormat='Active: {0}'}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <views:CustomersMapView IsVisible="{Binding IsMapView}"
                                        IsNativeMapVisible="{Binding IsNativeMapVisible}"
                                        IsWebMapVisible="{Binding IsWebMapVisible}"
                                        WebMapHtml="{Binding Map.WebMapHtml}"
                                        Markers="{Binding Map.Markers}"
                                        MarkerSelectedCommand="{Binding SelectMapMarkerCommand}" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
