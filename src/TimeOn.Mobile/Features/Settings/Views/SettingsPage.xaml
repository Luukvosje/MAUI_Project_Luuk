<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TimeOn.Mobile.Features.Settings.ViewModels"
             x:Class="TimeOn.Mobile.Features.Settings.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <VerticalStackLayout Padding="24" Spacing="16">
        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding IsDevelopmentModeSupported}">
            <Label Text="Development mode"
                   FontSize="18"
                   FontAttributes="Bold" />
            <Label Text="Enable GPS paste and dev tools on the Tracking page (Windows only)."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
            <Switch IsToggled="{Binding IsDevelopmentModeEnabled}" />
        </VerticalStackLayout>

        <Button Text="Logout" Command="{Binding LogoutCommand}" />
    </VerticalStackLayout>
</ContentPage>
