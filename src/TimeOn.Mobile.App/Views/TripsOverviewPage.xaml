<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TimeOn.Mobile.Core.Models;assembly=TimeOn.Mobile.Core"
             xmlns:viewModels="clr-namespace:TimeOn.Mobile.App.ViewModels"
             x:Class="TimeOn.Mobile.App.Views.TripsOverviewPage"
             x:DataType="viewModels:TripsOverviewViewModel"
             Title="{Binding Title}">
    <VerticalStackLayout Padding="16" Spacing="12">
        <Button Text="Refresh trips" Command="{Binding LoadCommand}" />
        <CollectionView ItemsSource="{Binding Trips}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Trip">
                    <Border Margin="0,4" Padding="8" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout>
                            <Label Text="{Binding StartTime}" />
                            <Label Text="{Binding DistanceKm, StringFormat='Distance: {0} km'}" />
                            <Label Text="{Binding CustomerName, StringFormat='Customer: {0}'}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
