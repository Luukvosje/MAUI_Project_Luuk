<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TimeOn.Mobile.Core.Models;assembly=TimeOn.Mobile.Core"
             xmlns:viewModels="clr-namespace:TimeOn.Mobile.App.ViewModels"
             x:Class="TimeOn.Mobile.App.Views.VisitsPage"
             x:DataType="viewModels:VisitsViewModel"
             Title="{Binding Title}">
    <VerticalStackLayout Padding="16" Spacing="12">
        <Button Text="Refresh visits" Command="{Binding LoadCommand}" />
        <CollectionView ItemsSource="{Binding Visits}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CustomerVisit">
                    <Border Margin="0,4" Padding="8" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout>
                            <Label Text="{Binding CustomerName}" />
                            <Label Text="{Binding ArrivedAt}" />
                            <Label Text="{Binding LeftAt}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
