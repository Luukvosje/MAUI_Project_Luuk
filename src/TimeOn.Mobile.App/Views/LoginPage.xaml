<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:TimeOn.Mobile.App.ViewModels"
             x:Class="TimeOn.Mobile.App.Views.LoginPage"
             x:DataType="viewModels:LoginViewModel"
             Title="{Binding Title}">
    <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="Sign in" Style="{StaticResource Headline}" />
        <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" />
        <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True" />
        <Button Text="Login" Command="{Binding LoginCommand}" />
        <Label Text="{Binding StatusMessage}" />
    </VerticalStackLayout>
</ContentPage>
